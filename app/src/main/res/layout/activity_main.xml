<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:padding="@dimen/title_padding"
        android:text="@string/app_name"
        android:textAlignment="center"
        android:textColor="@color/bg_light"
        android:textFontWeight="400"
        android:textSize="@dimen/title_text_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/taskTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/horizontal_margin"
        android:layout_marginTop="20dp"
        android:background="@color/accent"
        android:padding="@dimen/h2_padding"
        android:text="@string/task_menu_title"
        android:textAlignment="center"
        android:textColor="@color/bg_light"
        android:textSize="@dimen/h2_text_size"
        app:layout_constraintTop_toBottomOf="@+id/appTitle"
        tools:layout_editor_absoluteX="16dp" />

    <LinearLayout
        android:id="@+id/createTaskLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/horizontal_margin"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/taskTitle"
        tools:layout_editor_absoluteX="9dp">

        <EditText
            android:id="@+id/taskTextbox"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:autofillHints=""
            android:hint="@string/add_task_hint"
            android:inputType="textNoSuggestions"
            android:paddingHorizontal="@dimen/h2_padding" />

        <ImageButton
            android:id="@+id/addTaskButton"
            android:layout_width="@dimen/btn_icon"
            android:layout_height="@dimen/btn_icon"
            android:layout_gravity="center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/add_task"
            android:src="@drawable/ic_add"
            app:tint="?attr/colorOnSurface" />
    </LinearLayout>

    <TextView
        android:id="@+id/taskMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textAlignment="center"
        android:textColor="@color/error"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@+id/createTaskLayout"
        tools:layout_editor_absoluteX="10dp" />

    <TextView
        android:id="@+id/emptyTasksMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="@string/no_tasks_message"
        app:layout_constraintTop_toBottomOf="@+id/createTaskLayout" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/taskRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/horizontal_margin"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/createTaskLayout"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>